{
  "name": "binance-alpha-trader-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix frontend && pip install -r backend/requirements.txt",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "uvicorn backend.server:app --host 0.0.0.0 --port 8000",
    "start:frontend": "npm start --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
